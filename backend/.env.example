# Magnetite Backend — Environment Variables
# Copy this file to backend/.env (or set vars in the environment before `cargo run`).
# The root .env.example is the canonical reference; this file covers backend-only vars.

# ── Database (required) ────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/magnetite

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# ── OAuth Providers ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/discord/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:8080/api/auth/gitlab/callback

# ── GitHub App (CI / WASM build pipeline) ─────────────────────────────────────
# Required only if you use the GitHub-App-based WASM build pipeline.
# The backend panics at startup if these are set to an invalid value, so leave
# them blank to disable the GitHub App integration in development.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Payments (non-custodial crypto — DECENTRALIZATION.md §3.6) ────────────────
# There is NO fiat, NO custody, NO payouts. Buyers pay sellers wallet→wallet and
# the signed receipt is the entitlement.
#
# Payment rail. Default `mock` = deterministic signed receipts, fully OFFLINE
# (zero external services — this is what CI and `magnetite dev` use).
PAYMENT_RAIL=mock

# Protocol fee in basis points, taken on top of the subtotal. Default 0.
PROTOCOL_FEE_BPS=0

# Operator wallet (hex Ed25519 pubkey) that receives hosting / paid-tier fees.
# Only needed if this node sells hosting or paid subscription tiers.
OPERATOR_WALLET_PUBKEY=

# Placeholder chain config — UNUSED by the mock rail. Reserved for the real
# on-chain rail (USDC on an L2, or Solana). See TODO(chain) in services/payment.rs.
CHAIN_RPC_URL=
CHAIN_ID=
STABLECOIN_ADDRESS=

# ── Email ──────────────────────────────────────────────────────────────────────
# Select transport: resend | ses
# Leave blank to disable transactional email (verification links will not be sent).
EMAIL_PROVIDER=resend

# Full sender address shown in the From header, e.g. "Magnetite <noreply@magnetite.gg>".
EMAIL_FROM=Magnetite <noreply@magnetite.gg>

# Resend transport (EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# AWS SES via SMTP transport (EMAIL_PROVIDER=ses)
# Use SES SMTP credentials from the AWS console, NOT regular IAM access keys.
# SMTP endpoint: email-smtp.<AWS_SES_REGION>.amazonaws.com:587
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASSWORD=
AWS_SES_REGION=us-east-1

# ── Media / Streaming ──────────────────────────────────────────────────────────
# Base URL of the external MediaMTX (or compatible HLS/RTMP) media server.
# The backend proxies /streams/:id/hls.m3u8 to this URL.
# Leave blank to disable live-stream watch (endpoint returns 503).
# Bucket-D external dependency: requires a separately deployed MediaMTX instance.
# PER-NODE MEDIA: this is THIS node's default only. A stream/room record carries
# its own `media_host`, which always wins — every operator runs their own media
# server and there is no single global one.
MEDIA_SERVER_BASE_URL=

# ── Comms provider (DECENTRALIZATION.md §3.5) ─────────────────────────────────
# Magnetite builds no chat/voice/video/streaming. Everything social sits behind
# ONE adapter seam and is served by an existing decentralized system.
#
#   builtin  (default) — the DEMOTED in-house stack (communities/channels/
#                        messages + ws/comms + ws/voice + streaming/MediaMTX).
#                        Requires ZERO external services and works offline.
#   matrix             — text / DMs / presence / spaces (Element homeserver)
#   jitsi              — voice + video SFU
#   livekit            — voice + video at scale
#   owncast            — live streaming / VOD
#
# A provider whose service is not configured below falls back to `builtin` with
# a warning — it never breaks the node.
COMMS_PROVIDER=builtin

# Node IdP key: 64 hex chars (32 bytes). The node mints every comms join
# credential from the player's keypair with this key, so one login SSOs into
# whichever comms system is wired. Unset -> an ephemeral key is generated at
# boot and credentials do not survive a restart.
NODE_SIGNING_SEED=

# Matrix — set MATRIX_HOMESERVER to enable. MATRIX_SHARED_SECRET is only needed
# if the homeserver trusts this node as a JWT/SSO identity provider.
MATRIX_HOMESERVER=
MATRIX_SERVER_NAME=
MATRIX_ALIAS_PREFIX=magnetite
MATRIX_SHARED_SECRET=

# Jitsi — set JITSI_DOMAIN to enable. The JWT pair is optional: an open Jitsi
# deployment needs neither, and clients just get a room URL.
JITSI_DOMAIN=
JITSI_APP_ID=magnetite
JITSI_JWT_SECRET=

# LiveKit — set LIVEKIT_URL to enable. Without the key/secret pair no access
# token can be minted and clients must authenticate to LiveKit themselves.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Owncast — set OWNCAST_URL to enable.
OWNCAST_URL=
OWNCAST_STREAM_KEY=


# ── Game Server WebSocket ──────────────────────────────────────────────────────
# WebSocket base URL used by matchmaking to set server_endpoint on new sessions.
# Default: ws://localhost:8080 (runs the game WS on the same server as the API).
# Bucket-D: dedicated game servers require separate deployment and this URL.
GAME_SERVER_WS_BASE=ws://localhost:8080

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for sliding-window rate limiting. Falls back to in-memory if absent.
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging / App ─────────────────────────────────────────────────────────────
RUST_LOG=info
APP_ENV=development
APP_URL=http://localhost:8080

# ── Super-Admin Control Panel ───────────────────────────────────────────────────
# Hardened, server-rendered panel at /superadmin (separate from /api/v1/admin).
# DISABLED unless both an email and a password/hash are set, so it adds zero
# attack surface when unused. Generate the argon2 hash with any argon2 tool,
# e.g.:  echo -n 'your-strong-password' | argon2 "$(openssl rand -hex 16)" -id -e
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD_HASH=
# Dev-only plaintext fallback (used only if HASH is unset). Do NOT use in prod.
SUPERADMIN_PASSWORD=
# Optional comma-separated IP / CIDR allowlist gating the entire panel.
# Empty = allow any source IP. Example: 203.0.113.4,10.0.0.0/8,2001:db8::/32
SUPERADMIN_IP_ALLOWLIST=
# Session lifetime (seconds) for an authenticated control session. Default 7200.
SUPERADMIN_SESSION_TTL_SECS=7200
# Force the Secure cookie flag. Defaults to true when APP_ENV=production.
SUPERADMIN_SECURE_COOKIE=

# ── In-house Analytics + GeoIP ──────────────────────────────────────────────────
# Request analytics are recorded in-process (no third-party calls). Set to
# false to disable recording entirely.
ANALYTICS_ENABLED=true
# Optional offline MaxMind GeoLite2-City .mmdb file for in-house IP geolocation.
# When unset, geo columns are left NULL (private/loopback IPs show as "Local").
GEOIP_DB_PATH=
# Trust X-Forwarded-For / X-Real-IP for the client IP (only enable behind a
# trusted reverse proxy — otherwise IPs are spoofable). Default false.
TRUST_PROXY=false
# Number of trusted proxies that append X-Forwarded-For (1 = a single nginx/CDN
# in front). The client IP is taken this many hops from the right, so a spoofed
# leftmost XFF can't bypass the super-admin IP allowlist or login lockout.
TRUSTED_PROXY_COUNT=1

# ── Super-admin session backend ─────────────────────────────────────────────────
# Sessions + login lockout use Redis (REDIS_URL above) when reachable, so they are
# shared across replicas and survive restarts. Set to "memory" to force in-process
# storage (single instance only).
SUPERADMIN_SESSION_BACKEND=

# ── Analytics sampling + retention ──────────────────────────────────────────────
# Fraction (0.0–1.0) of successful (<400) requests to persist; error responses are
# always recorded. Default 1.0 (record everything). Lower it under heavy traffic.
ANALYTICS_SAMPLE_RATE=1.0
# Days of analytics history to keep; a background job prunes older rows. Default 90.
ANALYTICS_RETENTION_DAYS=90
# Header carrying a CDN-resolved country code, used as a geo fallback when no
# GeoIP database resolves the IP (only trusted when TRUST_PROXY=true). Default
# cf-ipcountry (Cloudflare). Set to your CDN's equivalent if different.
GEO_COUNTRY_HEADER=cf-ipcountry
