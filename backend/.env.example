# Magnetite Backend — Environment Variables
# Copy this file to backend/.env (or set vars in the environment before `cargo run`).
# The root .env.example is the canonical reference; this file covers backend-only vars.

# ── Database (required) ────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/magnetite

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# ── OAuth Providers ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/discord/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:8080/api/auth/gitlab/callback

# ── GitHub App (CI / WASM build pipeline) ─────────────────────────────────────
# Required only if you use the GitHub-App-based WASM build pipeline.
# The backend panics at startup if these are set to an invalid value, so leave
# them blank to disable the GitHub App integration in development.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Payments ───────────────────────────────────────────────────────────────────
# Paystack secret key for fiat on-ramp (deposits + subscriptions).
# If unset, Paystack endpoints return HTTP 502.
PAYSTACK_SECRET_KEY=

# Wise (TransferWise) API token — used for developer payout disbursements.
# If unset, payout endpoints return HTTP 502 (ProviderUnconfigured) — no fake success.
WISE_API_TOKEN=

# Wise profile ID — the sending business/personal profile for outbound transfers.
# Find yours at https://wise.com/user/account (Settings → Profile details).
WISE_PROFILE_ID=

# When WISE_SANDBOX=true, requests go to api.sandbox.transferwise.tech.
# Results are clearly labelled as sandbox — safe for local dev / CI. Default: false.
WISE_SANDBOX=false

# Set to true in local dev / CI to enable sandbox mode across all payment providers.
# The backend returns clearly-labelled placeholder results (does NOT fabricate real transfers).
PAYMENTS_SANDBOX=false

# ── Email ──────────────────────────────────────────────────────────────────────
# Select transport: resend | ses
# Leave blank to disable transactional email (verification links will not be sent).
EMAIL_PROVIDER=resend

# Full sender address shown in the From header, e.g. "Magnetite <noreply@magnetite.gg>".
EMAIL_FROM=Magnetite <noreply@magnetite.gg>

# Resend transport (EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# AWS SES via SMTP transport (EMAIL_PROVIDER=ses)
# Use SES SMTP credentials from the AWS console, NOT regular IAM access keys.
# SMTP endpoint: email-smtp.<AWS_SES_REGION>.amazonaws.com:587
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASSWORD=
AWS_SES_REGION=us-east-1

# ── Media / Streaming ──────────────────────────────────────────────────────────
# Base URL of the external MediaMTX (or compatible HLS/RTMP) media server.
# The backend proxies /streams/:id/hls.m3u8 to this URL.
# Leave blank to disable live-stream watch (endpoint returns 503).
# Bucket-D external dependency: requires a separately deployed MediaMTX instance.
MEDIA_SERVER_BASE_URL=

# ── Game Server WebSocket ──────────────────────────────────────────────────────
# WebSocket base URL used by matchmaking to set server_endpoint on new sessions.
# Default: ws://localhost:8080 (runs the game WS on the same server as the API).
# Bucket-D: dedicated game servers require separate deployment and this URL.
GAME_SERVER_WS_BASE=ws://localhost:8080

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for sliding-window rate limiting. Falls back to in-memory if absent.
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging / App ─────────────────────────────────────────────────────────────
RUST_LOG=info
APP_ENV=development
APP_URL=http://localhost:8080
