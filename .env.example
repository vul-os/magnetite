# Magnetite — Root Environment Variables
# Copy this file to .env and fill in the values before starting the stack.
# Frontend (Vite) env vars are prefixed VITE_*; backend vars are read by the Rust binary.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/magnetite

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
FRONTEND_URL=http://localhost:5173

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# ── OAuth Providers ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/discord/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:8080/api/auth/gitlab/callback

# ── Payments ───────────────────────────────────────────────────────────────────
# Paystack secret key for fiat on-ramp (deposits + subscriptions).
# If unset, Paystack endpoints return HTTP 502. Required for live fiat payments.
PAYSTACK_SECRET_KEY=

# Wise (TransferWise) API token — used for developer payout disbursements.
# If unset, payout endpoints return HTTP 502 (ProviderUnconfigured) — no fake success.
# Required for live payouts to developers.
WISE_API_TOKEN=

# Wise profile ID — the sending business/personal profile to use for transfers.
# Find yours at https://wise.com/user/account (Settings → Profile details).
WISE_PROFILE_ID=

# When WISE_SANDBOX=true, requests go to api.sandbox.transferwise.tech and results
# are clearly labelled as sandbox — safe for local dev/CI. Default: false.
WISE_SANDBOX=false

# When PAYMENTS_SANDBOX=true the backend returns clearly-labelled sandbox results
# even when provider keys are absent — safe for local dev/CI. Default: false.
PAYMENTS_SANDBOX=false

# ── Email ──────────────────────────────────────────────────────────────────────
# Select the outbound email transport: resend | ses
# If the selected provider's credentials are absent, send_email returns a clear
# error (no silent no-op). Leave EMAIL_PROVIDER blank to disable outbound email.
EMAIL_PROVIDER=resend

# Sender address used in the From header of all outbound emails.
EMAIL_FROM=Magnetite <noreply@magnetite.gg>

# Resend (https://resend.com) — one API key, zero SMTP setup. Recommended.
RESEND_API_KEY=

# AWS SES via SMTP — uses lettre SMTP transport to email-smtp.<region>.amazonaws.com.
# Generate SES SMTP credentials in the AWS console (IAM → SES SMTP credentials).
# These are distinct from standard IAM access keys.
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASSWORD=
AWS_SES_REGION=us-east-1

# ── Media / Streaming ──────────────────────────────────────────────────────────
# Base URL of the MediaMTX (or equivalent) media server used for HLS streaming
# and RTMP egress. The backend constructs HLS manifest URLs from this base and
# proxies or redirects /streams/:id/hls.m3u8 to it.
# Leave blank to disable live-stream watch support (endpoint returns 503).
# Example (Docker Compose): http://mediamtx:8888
# Bucket-D: requires a separately deployed MediaMTX instance — not shipped.
MEDIA_SERVER_BASE_URL=

# ── Game Server WebSocket ──────────────────────────────────────────────────────
# WebSocket base URL for dedicated game servers. Matchmaking sets server_endpoint
# on new sessions using this base + the session ID.
# Defaults to the same host as the backend (single-server dev mode).
# Bucket-D: dedicated / auto-scaled game servers require separate deployment.
GAME_SERVER_WS_BASE=ws://localhost:8080

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:8080

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# These are injected at build time by Vite (import.meta.env.*).
# Copy into a .env file at the repo root; Vite picks them up automatically.

# Backend API base URL (no trailing slash).
VITE_API_URL=http://localhost:8080

# When true, all hooks and pages fall back to static mock data instead of fetching
# from the backend. Useful for UI-only development without a running backend.
# Default: false (real API calls, real errors).
VITE_USE_MOCKS=false

# When true, useWebSocket substitutes a local mock socket instead of opening a
# real browser WebSocket. Implies no real-time data from the backend.
# Default: false (real WebSocket connections).
VITE_USE_MOCK_WS=false
